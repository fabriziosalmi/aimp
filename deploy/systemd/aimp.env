# AIMP Node Environment Configuration
# Copy to /etc/aimp/aimp.env and edit as needed.
# These override aimp.toml defaults.

# AIMP_PORT=1337
# AIMP_METRICS_PORT=9090
# AIMP_NOISE_REQUIRED=true
# AIMP_PEER_RATE_LIMIT=50
# AIMP_PEER_RATE_BURST=100
# AIMP_QUORUM_THRESHOLD=2
# AIMP_GC_MUTATION_THRESHOLD=1000
# AIMP_DAG_HISTORY_DEPTH=100
